# Doble 9's — consolidated env reference (CLAUDE.md §10).
# Frontend: copy the VITE_* block to frontend/.env.local
# Backend:  copy the rest to backend/.env  (or use backend/.env.example)

# ── Frontend (frontend/.env.local) ────────────────────────────────────────
# DEV: MSW + WS-fake activos. En PROD (Vercel): VITE_USE_MOCKS=false y URLs
# reales del backend en Render (https/wss). Ver docs/DEPLOY.md §2 y ADR-012.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/game
VITE_USE_MOCKS=true
VITE_GEMINI_API_KEY=your_gemini_key
VITE_SENTRY_DSN=

# ── Backend (backend/.env) ────────────────────────────────────────────────
# CORS_ORIGINS admite entradas exactas y wildcards para preview deploys de
# Vercel (ADR-012). Ejemplo prod:
#   CORS_ORIGINS=https://doble9s.vercel.app,https://doble9s-*.vercel.app
DATABASE_URL=postgresql+asyncpg://doble9s:doble9s@localhost:5432/doble9s
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
GEMINI_API_KEY=your_gemini_key
CORS_ORIGINS=http://localhost:5173,https://doble9s.com

# ── docker-compose (backend/docker-compose.yml) ───────────────────────────
POSTGRES_USER=doble9s
POSTGRES_PASSWORD=doble9s
POSTGRES_DB=doble9s
# Si tienes un Postgres NATIVO en el host ocupando 5432, usa otro puerto:
#   POSTGRES_PORT=5433  + DATABASE_URL=...@localhost:5433/doble9s
POSTGRES_PORT=5432
