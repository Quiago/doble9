# Copy to .env and fill real values. .env is gitignored.
DATABASE_URL=postgresql+asyncpg://doble9s:doble9s@localhost:5432/doble9s
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
GEMINI_API_KEY=your_gemini_key

# CORS_ORIGINS: comma-separated allowed origins for the browser SPA.
# Entries containing `*` are compiled into a regex and matched via Starlette's
# `allow_origin_regex` — use this for Vercel preview deploys, whose hostnames
# vary per branch/PR. `*` only matches one host label (no slashes), so a
# pattern cannot match a different host.
#
# Production example (Vercel prod URL + previews):
#   CORS_ORIGINS=https://doble9s.vercel.app,https://doble9s-*.vercel.app
#
# Local dev default:
CORS_ORIGINS=http://localhost:5173,https://doble9s.com
