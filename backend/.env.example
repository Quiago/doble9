# Copy to .env and fill real values. .env is gitignored.
DATABASE_URL=postgresql+asyncpg://doble9s:doble9s@localhost:5432/doble9s
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
GEMINI_API_KEY=your_gemini_key
# CORS_ORIGINS: lista separada por comas. Admite wildcards `*` para preview
# deploys de Vercel (ADR-012). El servidor convierte cada entrada con `*`
# en un regex y la pasa via `allow_origin_regex` de Starlette CORS.
# Dev:  http://localhost:5173
# Prod: https://doble9s.vercel.app,https://doble9s-*.vercel.app
CORS_ORIGINS=http://localhost:5173,https://doble9s.com
