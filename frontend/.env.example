# Frontend env (copy to .env.local). See CLAUDE.md §10.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/game
VITE_GEMINI_API_KEY=
VITE_SENTRY_DSN=
# Work against MSW + WS-fake until the real backend is up (frontend plan Bloque A).
VITE_USE_MOCKS=true

# ---------------------------------------------------------------------------
# Production reference (set these in the Vercel dashboard, NOT in this file).
# See docs/DEPLOY.md §2 and ADR-008. Replace <svc> with your Render service.
# ---------------------------------------------------------------------------
# VITE_API_URL=https://<svc>.onrender.com
# VITE_WS_URL=wss://<svc>.onrender.com/game
# VITE_USE_MOCKS=false
# VITE_GEMINI_API_KEY=         # optional; avatars degrade gracefully if blank
# VITE_SENTRY_DSN=             # optional
